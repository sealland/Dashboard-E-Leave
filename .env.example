# SQL Server connection (copy to .env and fill in real values)
DB_SERVER=localhost
DB_PORT=1433
DB_NAME=HR_Approve
DB_USER=your_username
DB_PASSWORD=your_password

# Windows Authentication (set DB_TRUSTED_CONNECTION=true to use; leave DB_USER/DB_PASSWORD empty)
DB_TRUSTED_CONNECTION=false

# ODBC driver name (check: odbcad32 -> Drivers tab)
DB_DRIVER=ODBC Driver 17 for SQL Server

# Optional: encrypt connection (recommended for production)
DB_ENCRYPT=yes
DB_TRUST_SERVER_CERTIFICATE=yes

# Dashboard server (0.0.0.0 = accessible on LAN)
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8000
