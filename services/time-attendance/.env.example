DB_SERVER=your-server-hostname
DB_PORT=1433
DB_DATABASE=INFO
# or use DB_NAME (repo root .env)
DB_NAME=INFO
DB_USER=your_sql_user
DB_PASSWORD=your_password
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true
API_PORT=8011
API_HOST=127.0.0.1
BASE_PATH=/hr-approve

# If unset, server/db.js also loads ../../.env from the repo root.
