{
  "name": "hr-approve",
  "version": "2.0.0",
  "private": true,
  "description": "HR Approval Dashboard — PM2 orchestration for FastAPI + Time Attendance",
  "scripts": {
    "setup": "npm install --prefix services/time-attendance",
    "setup:python": "python -m pip install -r requirements.txt",
    "pm2:start": "pm2 start ecosystem.config.cjs",
    "pm2:restart": "pm2 restart ecosystem.config.cjs",
    "pm2:reload": "pm2 reload ecosystem.config.cjs",
    "pm2:stop": "pm2 stop ecosystem.config.cjs",
    "pm2:delete": "pm2 delete ecosystem.config.cjs",
    "pm2:status": "pm2 status",
    "pm2:logs": "pm2 logs",
    "pm2:save": "pm2 save",
    "deploy": "npm run setup && pm2 start ecosystem.config.cjs"
  }
}
